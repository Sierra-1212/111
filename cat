        }
    });

    // 健康风险预测图
    const ctxHealth = document.getElementById('healthChart').getContext('2d');
    new Chart(ctxHealth, {
        type: 'radar',
        data: {
            labels: ['关节疾病', '皮肤病', '消化系统', '牙科疾病', '肥胖风险', '传染病'],
            datasets: [{
                label: '健康风险指数',
                data: [65, 45, 30, 55, 70, 25],
                backgroundColor: 'rgba(58,123,58,0.2)',
                borderColor: '#3a7b3a',
                pointBackgroundColor: '#3a7b3a'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { tooltip: { callbacks: { label: (ctx) => `风险指数: ${ctx.raw}` } } }
        }
    });

    // 智能问答模拟
    const qaMap = new Map([
        ["手术可以分期", "当然可以！宠融助手提供0息医疗分期服务，单笔最高5万元，合作医院直付。根据您的信用评估，预计可审批额度2.8万元，年化利率0%-8.8%。具体以审批为准。"],
        ["宠物保险", "根据您宠物的品种、年龄和地理位置，我们推荐众安在线的宠物医疗险，覆盖100+常见疾病，年度保额3万元，月付仅需38元。还可享受免费体检1次。"]
    ]);
    const sourceMap = new Map([
        ["手术可以分期", "来源：宠融AI · 合作金融机构信贷政策"],
        ["宠物保险", "来源：众安在线·宠物医疗险产品库"]
    ]);
    const defaultAnswer = "感谢您的咨询！根据PetFin AI分析，您可以考虑宠医分期或宠物保险产品。建议先为爱宠建立数字身份档案（上传照片即可），我们将为您生成专属金融服务方案。如需人工客服，可拨打400-xxx-xxxx。";
    const defaultSource = "来源：宠融助手AI知识库";

    function getAnswer(question) {
        const normalized = question.trim().toLowerCase();
        if (normalized.includes("分期") || normalized.includes("手术")) {
            return { text: qaMap.get("手术可以分期"), source: sourceMap.get("手术可以分期") };
        } else if (normalized.includes("保险")) {
            return { text: qaMap.get("宠物保险"), source: sourceMap.get("宠物保险") };
        }
        return { text: defaultAnswer, source: defaultSource };
    }

    const chatContainer = document.getElementById('chatMessages');
    const inputEl = document.getElementById('questionInput');
    const sendBtn = document.getElementById('sendBtn');

    function appendMessage(role, text, source = null) {
        const msgDiv = document.createElement('div');
        msgDiv.className = `message ${role}`;
        const bubbleDiv = document.createElement('div');
        bubbleDiv.className = 'bubble';
        bubbleDiv.innerHTML = text.replace(/\n/g, '<br>');
        if (source && role === 'assistant') {
            const sourceSpan = document.createElement('div');
            sourceSpan.className = 'source-ref';
            sourceSpan.innerHTML = `<i class="fas fa-link"></i> ${source}`;
            bubbleDiv.appendChild(sourceSpan);
        }
        msgDiv.appendChild(bubbleDiv);
        chatContainer.appendChild(msgDiv);
        chatContainer.scrollTop = chatContainer.scrollHeight;
    }

    function handleUserQuestion() {
        const q = inputEl.value.trim();
        if (!q) return;
        appendMessage('user', q);
        inputEl.value = '';
        setTimeout(() => {
            const { text, source } = getAnswer(q);
            appendMessage('assistant', text, source);
        }, 400);
    }

    sendBtn.addEventListener('click', handleUserQuestion);
    inputEl.addEventListener('keypress', (e) => { if (e.key === 'Enter') handleUserQuestion(); });
    
    const startDemoBtn = document.getElementById('startDemoBtn');
    const demoBtnNav = document.getElementById('demoBtn');
    const demoSection = document.getElementById('demo');
    if (startDemoBtn) startDemoBtn.addEventListener('click', () => demoSection.scrollIntoView({ behavior: 'smooth' }));
    if (demoBtnNav) demoBtnNav.addEventListener('click', () => demoSection.scrollIntoView({ behavior: 'smooth' }));
</script>
</body>
</html>
